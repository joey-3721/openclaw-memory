{% extends 'base.html' %}
{% block content %}
<section class="hero">
  <div class="hero-copy">
    <div class="eyebrow">你的私人影音中心</div>
    <h1>今晚看什么，不用再纠结</h1>
    <p>基于你的豆瓣历史、评分、想看列表和口味画像，给你更像样的推荐理由、更顺手的移动端体验、以及更像流媒体产品的视觉表现。</p>
    <div class="actions">
      <a class="btn primary" href="/recommendations">看今日推荐</a>
      <a class="btn accent" href="/recommendations?sort=random">🎲 随机一部</a>
      <a class="btn" href="/recommendations#tonight">今晚看什么</a>
      <a class="btn" href="/library">逛影视库</a>
    </div>
  </div>
</section>

<section class="stats-grid">
  <div class="card stat">
    <span class="stat-label">看过</span>
    <strong class="stat-num">{{ counts.get('collect', 0) }}</strong>
  </div>
  <div class="card stat">
    <span class="stat-label">想看</span>
    <strong class="stat-num">{{ counts.get('wish', 0) }}</strong>
  </div>
  <div class="card stat">
    <span class="stat-label">高分样本</span>
    <strong class="stat-num">{{ profile.high_rated_count }}</strong>
  </div>
  <div class="card stat">
    <span class="stat-label">已评分</span>
    <strong class="stat-num">{{ profile.rated_count }}</strong>
  </div>
</section>

{% if recs %}
<section class="panel">
  <div class="panel-header">
    <h2>今日推荐</h2>
    <a href="/recommendations" class="link">查看更多 →</a>
  </div>
  <div class="rec-grid">
    {% for item in recs %}
    <article class="rec-card compact">
      <div class="rec-cover" style="{{ item._cover_style if item._cover_style else 'background: linear-gradient(135deg,#243060,#10182e)' }}">
        {% if item._cover_url %}<img src="{{ item._cover_url }}" alt="{{ item.title }}" loading="lazy" onerror="this.style.display='none'">{% endif %}
        <div class="rec-cover-overlay">
          <span class="rec-badge">{{ item.kind or 'unknown' }}</span>
          <div class="rec-rating-badge">{{ item.douban_rating or '-' }}</div>
        </div>
      </div>
      <div class="rec-body">
        <div class="rec-title-row">
          <h3 class="rec-title">{{ item.title }}</h3>
          {% if item._first_genre %}<span class="rec-genre-chip">{{ item._first_genre }}</span>{% endif %}
        </div>
        <div class="rec-meta-row">
          <span class="rec-year">{{ item.year }}</span>
          {% if item._stars %}<span class="rec-stars">{{ item._stars }}</span>{% endif %}
        </div>
        <div class="rec-reason-wrap">
          <span class="rec-reason-icon">💡</span>
          <p class="rec-reason">{{ item._reason }}</p>
        </div>
        {% if item.directors or item.actors %}
        <p class="rec-credits">{{ item.directors[:30] }}{% if item.directors and item.actors %} · {% endif %}{{ item.actors[:40] }}</p>
        {% endif %}
        <div class="rec-actions">
          <a class="btn small" href="{{ item.url }}" target="_blank">豆瓣详情</a>
          <a class="btn small" href="/recommendations">更多推荐</a>
        </div>
      </div>
    </article>
    {% endfor %}
  </div>
</section>
{% endif %}

<section class="two-col">
  <div class="panel">
    <div class="panel-header"><h2>口味画像</h2></div>
    <div class="section-sub">热门题材</div>
    <div class="chips">
      {% for name, count in profile.top_genres %}
      <span class="chip accent">{{ name }} <em>{{ count }}</em></span>
      {% endfor %}
    </div>
    <div class="section-sub" style="margin-top:16px">产地分布</div>
    <div class="chips">
      {% for name, count in profile.top_countries %}
      <span class="chip">{{ name }} <em>{{ count }}</em></span>
      {% endfor %}
    </div>
  </div>
  <div class="panel">
    <div class="panel-header"><h2>最近看过</h2><a href="/library?status=collect" class="link">查看全部 →</a></div>
    <div class="list">
      {% for item in recent %}
      <a class="list-item" href="{{ item.url }}" target="_blank">
        <div>
          <strong>{{ item.title }}</strong>
          <div class="muted">{{ item.watched_date or '未知时间' }} · {{ item.kind }} · {{ item.year }}</div>
          {% if item.comment %}<div class="comment-preview">"{{ item.comment[:40] }}"</div>{% endif %}
        </div>
        {% if item.my_rating %}
        <div class="my-rating-badge">{{ item.my_rating }}★</div>
        {% endif %}
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Staggered card entry animation
  document.querySelectorAll('.rec-card, .stat').forEach(function(el, i) {
    el.style.animationDelay = (i * 45) + 'ms';
  });

  // Watch / Rewatch buttons in tonight card and recent list
  document.querySelectorAll('.watch-btn, .rewatch-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id = this.dataset.id;
      var action = this.dataset.action;
      fetch('/api/' + action + '/' + id, { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.ok) {
            if (action === 'watch') {
              btn.textContent = '已看 ✓';
              btn.disabled = true;
            } else {
              btn.textContent = '再看 ' + data.watch_count + '次 ✓';
            }
          }
        }).catch(function(e) { console.error(e); });
    });
  });
});
</script>
{% endblock %}
